# =============================================
# Naipes Negros Backend — Environment Variables
# =============================================

# Environment
NODE_ENV=development

# Server
PORT=3001
HOST=0.0.0.0

# Database (MySQL 8.0)
DATABASE_URL="mysql://user:password@localhost:3306/naipes?schema=public"

# Redis (for future caching/sessions)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# JWT Authentication
JWT_SECRET=change-this-to-a-random-64-char-string
JWT_REFRESH_SECRET=change-this-to-another-random-64-char-string
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# CORS (comma-separated origins)
CORS_ORIGIN=http://localhost:3000,http://localhost:8080

# WebSocket
WS_PING_TIMEOUT=5000
WS_PING_INTERVAL=25000

# Email (SMTP)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your-email@gmail.com
EMAIL_PASSWORD=your-app-password
EMAIL_FROM=Naipes Negros <noreply@naipesnegros.com>

# Application URL (for email links, password reset, etc.)
APP_URL=http://localhost:3001

# Admin (comma-separated emails that have admin access)
ADMIN_EMAILS=admin@naipesnegros.com

# Firebase (Push Notifications)
# Path to Firebase service account JSON file
FIREBASE_SERVICE_ACCOUNT_PATH=./naipes-s-firebase-adminsdk.json
# Or use project ID with application default credentials
# FIREBASE_PROJECT_ID=naipes-s

# In-App Purchase Verification
# Set to 'true' to skip IAP receipt verification (development only!)
IAP_SKIP_VERIFICATION=true
# Google Play package name
GOOGLE_PLAY_PACKAGE_NAME=com.blkpos.naipesnegros
# Apple shared secret (for App Store receipt verification)
# APPLE_SHARED_SECRET=your-apple-shared-secret

# Game Settings
DEFAULT_COINS=1000
MIN_WITHDRAW_AMOUNT=500
DAILY_BONUS=100

# File Upload
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=5242880

# Image Server (legacy)
IMAGES_BASE_URL=https://naipes-images-3.blkpos.com

# Logging
LOG_LEVEL=info
LOG_DIR=./logs
